[Unit]
Description=Cloudflare Tunnel for lm-database
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=matt
ExecStart=/usr/local/bin/cloudflared tunnel --config /etc/cloudflared/config.yml run lm-database
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
