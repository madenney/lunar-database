MONGODB_URI=mongodb://localhost:27017/lm-database
PORT=3002
SLP_ROOT_DIR=/path/to/your/slp/files
BUNDLES_DIR=/path/to/bundles/output
BUNDLE_MAX_AGE_HOURS=72
CRAWLER_BATCH_SIZE=100
AIRLOCK_DIR=/path/to/airlock
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# Cloudflare R2 storage
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=lm-replays

# Job settings
JOB_MAX_REPLAYS=5000
JOB_BUNDLE_EXPIRY_HOURS=48
JOB_TEMP_DIR=/tmp/lm-job-temp
