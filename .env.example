MONGODB_URI=mongodb://localhost:27017/lm-database
PORT=3002
SLP_ROOT_DIR=/path/to/your/slp/files
AIRLOCK_DIR=/path/to/airlock
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# Email alerts
GMAIL_APP_PASSWORD=your-gmail-app-password
ALERT_EMAIL_FROM=your-gmail@gmail.com
ALERT_EMAIL_TO=your-alert-recipient@gmail.com

# Backblaze B2 storage (S3-compatible API)
S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com
S3_REGION=us-east-005
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET_NAME=lm-replays

# Job settings
JOB_TEMP_DIR=/var/lib/lm-database/temp
